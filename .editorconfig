root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.ts]
indent_size = 2
max_line_length = 120

[*.html]
indent_size = 2

[*.scss]
indent_size = 2

[*.json]
indent_size = 2
